---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import ProjectDetailPage from '../../components/ProjectDetailPage';
import { initDB, getPool } from '../../lib/db';
import { getProject } from '../../data/projects';
import type { Project } from '../../data/projects';

const { slug } = Astro.params;

await initDB();
type ProjRow = {
  slug: string; title: string; service: string; service_slug: string;
  cover_img: string; tagline: string; description: string;
  what: string[]; results: { value: string; label: string }[]; year: string;
};
const res = await getPool().query<ProjRow>(
  'SELECT * FROM projects_db WHERE slug=$1 AND published=true', [slug]
);

let project: Project | undefined;
if (res.rowCount) {
  const r = res.rows[0];
  project = {
    slug:        r.slug,
    title:       r.title,
    service:     r.service,
    serviceSlug: r.service_slug,
    img:         r.cover_img,
    tagline:     r.tagline,
    description: r.description,
    what:        Array.isArray(r.what) ? r.what : [],
    results:     Array.isArray(r.results) ? r.results : [],
    year:        r.year,
  };
} else {
  project = getProject(slug!);
}

if (!project) return Astro.redirect('/');
---

<Layout
  title={`${project.title} — ${project.service}`}
  description={`${project.tagline} Scopri come ED Digital Agency ha realizzato il progetto ${project.title}: ${project.description.slice(0, 120)}...`}
>
  <ProjectDetailPage client:load project={project} />
</Layout>
