---
export const prerender = false;
const auth  = Astro.cookies.get('ed-admin');
const stored = process.env.ADMIN_PASSWORD ?? '';
if (stored && auth?.value === stored) return Astro.redirect('/admin');
const err = Astro.url.searchParams.get('err'); // '1' = wrong pwd, '2' = rate limited
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Admin — ED Digital Agency</title>
  <meta name="robots" content="noindex,nofollow" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#0a0a0a;color:#fff;font-family:system-ui,sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;}
    .card{background:#111;border:1px solid rgba(255,255,255,.07);border-radius:20px;padding:48px 40px;width:100%;max-width:400px;}
    .logo{font-size:13px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-bottom:32px;}
    h1{font-size:26px;font-weight:700;margin-bottom:8px;}
    p{color:rgba(255,255,255,.4);font-size:14px;margin-bottom:32px;}
    label{display:block;font-size:12px;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.4);margin-bottom:8px;}
    input{width:100%;padding:14px 16px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:10px;color:#fff;font-size:15px;outline:none;}
    input:focus{border-color:#FF6A00;}
    button{margin-top:20px;width:100%;padding:14px;background:#FF6A00;color:#000;font-weight:700;font-size:14px;text-transform:uppercase;letter-spacing:.1em;border:none;border-radius:10px;cursor:pointer;}
    button:hover{background:#ff8c00;}
    .err{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:#f87171;padding:12px 16px;border-radius:8px;font-size:13px;margin-bottom:20px;}
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">ED Digital Agency</div>
    <h1>Admin Panel</h1>
    <p>Inserisci la password per accedere</p>
    {err === '1' && <div class="err">Password errata. Riprova.</div>}
    {err === '2' && <div class="err">Troppi tentativi. Riprova tra 15 minuti.</div>}
    <form method="POST" action="/api/admin/login">
      <label for="pwd">Password</label>
      <input id="pwd" name="password" type="password" placeholder="••••••••" autofocus required />
      <button type="submit">Accedi →</button>
    </form>
  </div>
</body>
</html>
