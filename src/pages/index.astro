---
import Layout from '../layouts/Layout.astro';

const services = [
  { name: 'Social Media Management', href: '#' },
  { name: 'Advertising',             href: '#' },
  { name: 'Website',                 href: '#' },
  { name: 'E-Commerce',              href: '#' },
  { name: 'Photo & Video',           href: '#' },
  { name: 'Visual Identity',         href: '#' },
  { name: 'MVP & SaaS',              href: '#' },
  { name: 'App',                     href: '#' },
];

const caseStudies = [
  { title: 'Italia Contract',    service: 'Web Design – Social Management', img: '/images/Cover-Italia-Contract.jpg' },
  { title: 'Val Longa',          service: 'Web Design',                     img: '/images/Cover-ValLonga.jpg' },
  { title: 'Espressione Danza',  service: 'Social Management',              img: '/images/Cover-Espressione-Danza.jpg' },
  { title: 'Ottica Toffoli',     service: 'Web Design',                     img: '/images/Cover-Otica-Toffoli.jpg' },
  { title: 'SoloMattia',         service: 'Social Management',              img: '/images/Cover-SoloMattia.jpg' },
  { title: 'Disegno Italia',     service: 'Web Design',                     img: '/images/Cover-Disegno-Italia.jpg' },
];

const partners = [
  { src: '/images/shopify-partner.png',           alt: 'Shopify Partner',    w: '62%' },
  { src: '/images/wordpress-logo-png-transparent.png', alt: 'WordPress',      w: '98%' },
  { src: '/images/keliweb-logo-e1522914795801.png', alt: 'Keliweb',          w: '69%' },
  { src: '/images/Logo-Litchi-solutions-intero.svg', alt: 'Litchi Solutions', w: '100%' },
  { src: '/images/ED-logo-completo.svg',           alt: 'ED Digital',        w: '100%' },
];
---

<Layout title="Partner Strategico Digitale">
  <main class="bg-black text-white min-h-screen font-sans">
    
    <section class="max-w-[1400px] mx-auto px-8 py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="space-y-8">
          <h1 class="text-7xl lg:text-9xl font-black uppercase leading-[0.9] tracking-tighter italic">
            La nostra <br/>
            <span class="text-[#FF6A00]">creatività</span> <br/>
            la tua visione.
          </h1>
          <p class="text-gray-400 text-xl max-w-md leading-relaxed">
            Siamo il motore digitale della tua crescita. Strategie sartoriali per brand che non temono di farsi notare.
          </p>
          <div class="flex gap-4">
            <a href="#casistudio" class="px-8 py-4 bg-[#FF6A00] text-black font-bold rounded-full hover:scale-105 transition-transform uppercase tracking-widest text-sm">
              I nostri lavori
            </a>
            <a href="mailto:ed.digitalagency@gmail.com" class="px-8 py-4 border border-white/20 rounded-full font-bold hover:bg-white hover:text-black transition-all uppercase tracking-widest text-sm">
              Contattaci
            </a>
          </div>
        </div>
        <div class="relative group">
          <div class="absolute -inset-10 bg-[#FF6A00]/10 blur-[120px] rounded-full group-hover:bg-[#FF6A00]/20 transition-all"></div>
          <img 
            src="/images/GrandeProgetto-sesnza-titolo-6-copia.png" 
            alt="Hero Agency" 
            class="relative z-10 w-full rounded-[3rem] grayscale hover:grayscale-0 transition-all duration-700 shadow-2xl"
          />
        </div>
      </div>
    </section>

    <section class="max-w-[1400px] mx-auto px-8 py-20">
      <h2 class="text-3xl font-bold mb-12 uppercase tracking-tighter italic">Cosa facciamo <span class="text-[#FF6A00]">/</span></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {services.map(s => (
          <div class="bg-[#0A0A0A] border border-white/5 p-10 rounded-[2.5rem] hover:border-[#FF6A00]/50 transition-all group relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-100 transition-opacity">
               <span class="text-[#FF6A00] text-4xl">→</span>
            </div>
            <h3 class="text-2xl font-bold group-hover:text-[#FF6A00] transition-colors">{s.name}</h3>
            <p class="mt-12 text-xs text-gray-500 uppercase tracking-widest">Digital Service</p>
          </div>
        ))}
      </div>
    </section>

    <section class="py-20" id="casistudio">
      <div class="max-w-[1400px] mx-auto px-8 mb-12">
        <h2 class="text-3xl font-bold uppercase tracking-tighter italic">Progetti Selezionati <span class="text-[#FF6A00]">/</span></h2>
      </div>
      <div class="flex gap-8 overflow-x-auto px-8 pb-10 no-scrollbar">
        {caseStudies.map(s => (
          <div class="min-w-[350px] lg:min-w-[450px] aspect-[4/5] relative rounded-[3rem] overflow-hidden group">
            <img 
               src={s.img} 
               alt={s.title} 
               class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" 
               onerror="this.src='https://placehold.co/600x800/111/white?text=Immagine+In+Arrivo'"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent opacity-80"></div>
            <div class="absolute bottom-10 left-10 right-10">
              <p class="text-[#FF6A00] font-black text-xs uppercase tracking-[0.3em] mb-3">{s.service}</p>
              <h3 class="text-3xl font-bold leading-none">{s.title}</h3>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="max-w-[1400px] mx-auto px-8 py-32 border-t border-white/5">
      <div class="flex flex-wrap justify-center items-center gap-12 lg:gap-24 opacity-30 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-1000">
        {partners.map(p => (
          <img src={p.src} alt={p.alt} class="h-8 lg:h-10 w-auto" />
        ))}
      </div>
    </section>

  </main>
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
