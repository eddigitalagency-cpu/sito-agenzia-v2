---
import Layout from '../layouts/Layout.astro';

const services = [
  { num: '01', name: 'Social Media Management', desc: 'Strategia, contenuti e community building.' },
  { num: '02', name: 'Advertising',             desc: 'Google Ads e Meta Ads ad alto ROI.' },
  { num: '03', name: 'Website',                 desc: 'Siti veloci, moderni e orientati alla conversione.' },
  { num: '04', name: 'E-Commerce',              desc: 'Shopify Partner. Negozi online che vendono.' },
  { num: '05', name: 'Photo & Video',           desc: 'Produzione visiva professionale per il tuo brand.' },
  { num: '06', name: 'Visual Identity',         desc: 'Logo, palette e brand kit coerenti e memorabili.' },
  { num: '07', name: 'MVP & SaaS',              desc: 'Sviluppo prodotto digitale dalla prototipazione al lancio.' },
  { num: '08', name: 'App',                     desc: 'Applicazioni mobile e web su misura.' },
];
---

<Layout title="Agenzia Digitale">

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="pt-40 pb-32 px-6 md:px-10 max-w-6xl mx-auto">
    <div class="max-w-4xl">

      <p class="text-xs font-semibold tracking-[0.22em] uppercase text-black/35 mb-10">
        Agenzia Digitale Italiana
      </p>

      <h1 class="text-[clamp(3rem,9vw,7.5rem)] font-bold leading-[0.95] tracking-tight mb-10">
        La nostra creatività<br />
        <em class="not-italic italic">la tua visione.</em>
      </h1>

      <p class="text-lg md:text-xl text-black/50 max-w-xl leading-relaxed mb-14">
        Trasformiamo idee in esperienze digitali memorabili.
        Strategia, design e performance al servizio del tuo brand.
      </p>

      <div class="flex items-center gap-5 flex-wrap">
        <a
          href="#services"
          class="inline-flex items-center gap-2 text-sm font-semibold bg-black text-white
                 px-7 py-3.5 rounded-full hover:bg-black/85 active:scale-95 transition-all duration-150"
        >
          Scopri di più
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#about"
          class="text-sm font-medium text-black/50 hover:text-black transition-colors duration-200"
        >
          Chi siamo
        </a>
      </div>

    </div>
  </section>

  <!-- ── Divider ───────────────────────────────────────────────── -->
  <div class="px-6 md:px-10 max-w-6xl mx-auto">
    <hr class="border-black/[0.08]" />
  </div>

  <!-- ── Di cosa ci occupiamo ──────────────────────────────────── -->
  <section id="services" class="px-6 md:px-10 py-28 max-w-6xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight leading-tight">
        Di cosa ci<br />occupiamo
      </h2>
      <p class="text-sm text-black/45 max-w-xs leading-relaxed">
        Otto aree di competenza integrate per costruire e far crescere la tua presenza digitale.
      </p>
    </div>

    <!-- Services list -->
    <ul class="divide-y divide-black/[0.07]">
      {services.map((s) => (
        <li>
          <a
            href="#contacts"
            class="group flex items-center gap-6 py-6 hover:pl-2 transition-all duration-300"
          >
            <span class="text-[11px] font-semibold text-black/25 w-6 shrink-0 tracking-wide">
              {s.num}
            </span>
            <span class="flex-1 text-xl md:text-2xl font-semibold tracking-tight group-hover:translate-x-1 transition-transform duration-300">
              {s.name}
            </span>
            <span class="hidden md:block text-sm text-black/35 max-w-[240px] leading-snug">
              {s.desc}
            </span>
            <span class="text-black/20 group-hover:text-black group-hover:translate-x-1 transition-all duration-300 shrink-0">
              →
            </span>
          </a>
        </li>
      ))}
    </ul>

  </section>

  <!-- ── Divider ───────────────────────────────────────────────── -->
  <div class="px-6 md:px-10 max-w-6xl mx-auto">
    <hr class="border-black/[0.08]" />
  </div>

  <!-- ── Chi Siamo ─────────────────────────────────────────────── -->
  <section id="about" class="px-6 md:px-10 py-28 max-w-6xl mx-auto">

    <div class="grid md:grid-cols-2 gap-16 md:gap-24 items-center">
      <div>
        <p class="text-xs font-semibold tracking-[0.22em] uppercase text-black/30 mb-6">
          Chi siamo
        </p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight leading-[1.05] mb-8">
          Il tuo partner<br />
          <em class="not-italic italic">strategico digitale.</em>
        </h2>
        <a
          href="#contacts"
          class="inline-flex items-center gap-2 text-sm font-semibold border border-black
                 px-7 py-3.5 rounded-full hover:bg-black hover:text-white active:scale-95
                 transition-all duration-200"
        >
          Lavoriamo insieme →
        </a>
      </div>
      <div>
        <p class="text-base md:text-lg text-black/55 leading-relaxed mb-6">
          Siamo un team di esperti digitali appassionati che aiuta le piccole imprese
          a crescere online. Partiamo dall'ascolto delle tue esigenze per costruire
          strategie su misura che uniscono creatività e dati.
        </p>
        <p class="text-base md:text-lg text-black/55 leading-relaxed">
          Non ci accontentiamo di semplici risultati: puntiamo a superare le aspettative,
          misurando costantemente l'efficacia delle nostre azioni e adattandoci ai
          cambiamenti del mercato.
        </p>
      </div>
    </div>

  </section>

  <!-- ── Collaboriamo? CTA ─────────────────────────────────────── -->
  <section class="px-6 md:px-10 py-32 max-w-6xl mx-auto text-center">

    <p class="text-xs font-semibold tracking-[0.22em] uppercase text-black/30 mb-8">
      Inizia il tuo progetto
    </p>
    <h2 class="text-5xl md:text-7xl lg:text-[90px] font-bold tracking-tight leading-[0.95] mb-10">
      Collaboriamo?
    </h2>
    <p class="text-base md:text-lg text-black/45 max-w-sm mx-auto leading-relaxed mb-12">
      Ogni grande progetto inizia con una conversazione.
    </p>
    <a
      href="mailto:ed.digitalagency@gmail.com"
      class="inline-flex items-center gap-2 text-sm font-semibold bg-black text-white
             px-10 py-4 rounded-full hover:bg-black/85 active:scale-95 transition-all duration-150"
    >
      Contattaci
      <span aria-hidden="true">→</span>
    </a>

  </section>

</Layout>
