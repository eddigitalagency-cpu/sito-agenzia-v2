---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Partner Strategico Digitale">

  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center justify-center px-6 pt-32 pb-24 overflow-hidden">

    <!-- Background radial glow -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2
                  w-[700px] h-[500px] bg-white/[0.025] rounded-full blur-[120px]">
      </div>
    </div>

    <div class="relative text-center max-w-4xl mx-auto">
      <p class="text-[10px] md:text-xs font-semibold tracking-[0.25em] text-white/35 uppercase mb-7">
        Agenzia Digitale Italiana
      </p>

      <h1 class="text-5xl md:text-7xl lg:text-[88px] font-bold tracking-tight leading-[1.04] mb-8">
        <span class="text-white">Creiamo esperienze</span><br />
        <span class="text-white/40">digitali uniche.</span>
      </h1>

      <p class="text-base md:text-lg text-white/45 max-w-lg mx-auto leading-relaxed mb-12">
        Il tuo partner strategico per crescere online. Uniamo creatività
        e dati per costruire brand che fanno la differenza.
      </p>

      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a
          href="#services"
          class="bg-white text-[#080808] font-semibold text-sm px-8 py-3.5 rounded-full
                 hover:bg-white/90 active:scale-95 transition-all duration-150"
        >
          Scopri i servizi
        </a>
        <a
          href="#about"
          class="text-white/60 text-sm px-8 py-3.5 rounded-full border border-white/[0.1]
                 hover:border-white/25 hover:text-white/90 transition-all duration-200"
        >
          Chi siamo →
        </a>
      </div>
    </div>
  </section>

  <!-- ── Services Bento Grid ────────────────────────────────── -->
  <section id="services" class="px-4 md:px-6 pb-32 max-w-5xl mx-auto">

    <div class="mb-14 text-center">
      <p class="text-[10px] tracking-[0.25em] text-white/30 uppercase mb-3">Cosa facciamo</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight">I nostri servizi</h2>
    </div>

    <!--
      Bento grid — 6 columns, 200 px auto-rows on desktop.
      Layout:
        Row 1–2 : Web Design (col 1-4) | Social Media (col 5-6, row 1) / Video (col 5-6, row 2)
        Row 3   : Advertising (col 1-3) | Shooting (col 4-6)
        Row 4–5 : E-commerce (col 1-4) | Branding (col 5-6, rows 4-5)
    -->
    <div class="grid grid-cols-1 gap-4 md:grid-cols-6 md:[grid-auto-rows:200px]">

      <!-- Web Design — large tall (4 col × 2 row) -->
      <div
        class="min-h-[360px] md:min-h-0
               md:col-start-1 md:col-end-5 md:row-start-1 md:row-end-3
               group relative overflow-hidden rounded-3xl
               border border-white/[0.07] bg-gradient-to-br from-white/[0.06] to-white/[0.02]
               p-8 md:p-10 flex flex-col justify-between
               transition-all duration-300
               hover:border-white/[0.13] hover:from-white/[0.09] hover:to-white/[0.04]
               cursor-pointer"
      >
        <span class="text-[10px] font-semibold tracking-[0.2em] text-white/30 uppercase">
          Design &amp; Sviluppo
        </span>
        <div>
          <h3 class="text-5xl md:text-6xl font-bold tracking-tight mb-5 mt-4">Web Design</h3>
          <p class="text-white/45 text-sm md:text-base leading-relaxed max-w-sm mb-6">
            Siti web moderni, veloci e ottimizzati per la conversione. Progettiamo esperienze
            digitali che raccontano il tuo brand e trasformano i visitatori in clienti.
          </p>
          <span class="text-xs text-white/25 group-hover:text-white/50 transition-colors">
            Scopri il servizio →
          </span>
        </div>
      </div>

      <!-- Social Media — small (2 col × 1 row) -->
      <div
        class="min-h-[180px] md:min-h-0
               md:col-start-5 md:col-end-7 md:row-start-1 md:row-end-2
               group relative overflow-hidden rounded-3xl
               border border-white/[0.07] bg-gradient-to-br from-blue-500/[0.09] to-blue-500/[0.01]
               p-7 flex flex-col justify-between
               transition-all duration-300
               hover:border-blue-400/25 hover:from-blue-500/[0.14]
               cursor-pointer"
      >
        <span class="text-[10px] font-semibold tracking-[0.2em] text-white/30 uppercase">Social</span>
        <div>
          <h3 class="text-2xl font-bold tracking-tight mb-1.5">Social Media</h3>
          <p class="text-white/40 text-xs leading-relaxed">
            Content strategy, gestione profili e community management.
          </p>
        </div>
      </div>

      <!-- Video — small (2 col × 1 row) -->
      <div
        class="min-h-[180px] md:min-h-0
               md:col-start-5 md:col-end-7 md:row-start-2 md:row-end-3
               group relative overflow-hidden rounded-3xl
               border border-white/[0.07] bg-gradient-to-br from-violet-500/[0.09] to-violet-500/[0.01]
               p-7 flex flex-col justify-between
               transition-all duration-300
               hover:border-violet-400/25 hover:from-violet-500/[0.14]
               cursor-pointer"
      >
        <span class="text-[10px] font-semibold tracking-[0.2em] text-white/30 uppercase">Produzione</span>
        <div>
          <h3 class="text-2xl font-bold tracking-tight mb-1.5">Video</h3>
          <p class="text-white/40 text-xs leading-relaxed">
            Video professionali per brand, campagne e social media.
          </p>
        </div>
      </div>

      <!-- Advertising — medium (3 col × 1 row) -->
      <div
        class="min-h-[200px] md:min-h-0
               md:col-start-1 md:col-end-4 md:row-start-3 md:row-end-4
               group relative overflow-hidden rounded-3xl
               border border-white/[0.07] bg-gradient-to-br from-amber-500/[0.08] to-amber-500/[0.01]
               p-7 md:p-8 flex flex-col justify-between
               transition-all duration-300
               hover:border-amber-400/25 hover:from-amber-500/[0.13]
               cursor-pointer"
      >
        <span class="text-[10px] font-semibold tracking-[0.2em] text-white/30 uppercase">Google &amp; Meta</span>
        <div>
          <h3 class="text-2xl md:text-3xl font-bold tracking-tight mb-2">Advertising</h3>
          <p class="text-white/40 text-xs md:text-sm leading-relaxed">
            Campagne Google Ads e Meta Ads ad alte prestazioni con ROI misurabile.
          </p>
        </div>
      </div>

      <!-- Shooting — medium (3 col × 1 row) -->
      <div
        class="min-h-[200px] md:min-h-0
               md:col-start-4 md:col-end-7 md:row-start-3 md:row-end-4
               group relative overflow-hidden rounded-3xl
               border border-white/[0.07] bg-gradient-to-br from-emerald-500/[0.08] to-emerald-500/[0.01]
               p-7 md:p-8 flex flex-col justify-between
               transition-all duration-300
               hover:border-emerald-400/25 hover:from-emerald-500/[0.13]
               cursor-pointer"
      >
        <span class="text-[10px] font-semibold tracking-[0.2em] text-white/30 uppercase">Fotografia</span>
        <div>
          <h3 class="text-2xl md:text-3xl font-bold tracking-tight mb-2">Shooting</h3>
          <p class="text-white/40 text-xs md:text-sm leading-relaxed">
            Fotografia professionale per prodotti, eventi e brand identity.
          </p>
        </div>
      </div>

      <!-- E-commerce — large tall (4 col × 2 row) -->
      <div
        class="min-h-[360px] md:min-h-0
               md:col-start-1 md:col-end-5 md:row-start-4 md:row-end-6
               group relative overflow-hidden rounded-3xl
               border border-white/[0.07] bg-gradient-to-br from-teal-500/[0.08] to-teal-500/[0.02]
               p-8 md:p-10 flex flex-col justify-between
               transition-all duration-300
               hover:border-teal-400/20 hover:from-teal-500/[0.12]
               cursor-pointer"
      >
        <span class="text-[10px] font-semibold tracking-[0.2em] text-white/30 uppercase">
          Shopify Partner
        </span>
        <div>
          <h3 class="text-5xl md:text-6xl font-bold tracking-tight mb-5 mt-4">E-commerce</h3>
          <p class="text-white/45 text-sm md:text-base leading-relaxed max-w-sm mb-6">
            Negozi online ad alte prestazioni. Come Shopify Partner certificato, costruiamo
            e-commerce ottimizzati per vendere di più, con un'esperienza utente impeccabile.
          </p>
          <span class="text-xs text-white/25 group-hover:text-white/50 transition-colors">
            Scopri il servizio →
          </span>
        </div>
      </div>

      <!-- Branding — tall (2 col × 2 row) -->
      <div
        class="min-h-[360px] md:min-h-0
               md:col-start-5 md:col-end-7 md:row-start-4 md:row-end-6
               group relative overflow-hidden rounded-3xl
               border border-white/[0.07] bg-gradient-to-br from-rose-500/[0.09] to-rose-500/[0.01]
               p-7 flex flex-col justify-between
               transition-all duration-300
               hover:border-rose-400/25 hover:from-rose-500/[0.14]
               cursor-pointer"
      >
        <span class="text-[10px] font-semibold tracking-[0.2em] text-white/30 uppercase">
          Brand Identity
        </span>
        <div>
          <h3 class="text-3xl font-bold tracking-tight mb-3">Branding</h3>
          <p class="text-white/40 text-sm leading-relaxed">
            Identità visiva coerente e memorabile che differenzia il tuo brand dalla
            concorrenza e crea connessioni reali con il pubblico.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ── About / CTA Strip ─────────────────────────────────── -->
  <section id="about" class="px-4 md:px-6 pb-32 max-w-5xl mx-auto">
    <div
      class="rounded-3xl border border-white/[0.07]
             bg-gradient-to-br from-white/[0.04] to-transparent
             p-12 md:p-20 text-center"
    >
      <p class="text-[10px] tracking-[0.25em] text-white/30 uppercase mb-5">Il nostro approccio</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight mb-6 max-w-2xl mx-auto leading-tight">
        Il partner strategico per<br class="hidden md:inline" />
        il tuo futuro digitale
      </h2>
      <p class="text-white/45 text-sm md:text-lg max-w-lg mx-auto leading-relaxed mb-10">
        Ascoltiamo, progettiamo, eseguiamo. Ogni progetto è un viaggio su misura che unisce
        creatività e dati per superare le aspettative e adattarsi al mercato.
      </p>
      <a
        href="#contacts"
        class="inline-block bg-white text-[#080808] font-semibold text-sm
               px-10 py-4 rounded-full hover:bg-white/90 active:scale-95
               transition-all duration-150"
      >
        Inizia il tuo progetto
      </a>
    </div>
  </section>

</Layout>
