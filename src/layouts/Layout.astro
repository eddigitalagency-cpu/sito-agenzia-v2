---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'ED Digital Agency — Il partner strategico per le piccole imprese che vogliono crescere online.',
} = Astro.props;
---

<!doctype html>
<html lang="it" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — ED Digital Agency</title>

    <style is:global>
      /* ── Custom Fonts ────────────────────────────────── */
      @font-face {
        font-family: 'CalSans';
        src: url('/fonts/CalSans-Regular.ttf') format('truetype');
        font-weight: 400 700;
        font-display: swap;
      }
      @font-face {
        font-family: 'GraphikLCG';
        src: url('/fonts/GraphikLCG-Extralight.woff2') format('woff2');
        font-weight: 200;
        font-display: swap;
      }
      @font-face {
        font-family: 'GraphikLCG';
        src: url('/fonts/GraphikLCG-Light.woff2') format('woff2');
        font-weight: 300;
        font-display: swap;
      }
      @font-face {
        font-family: 'GraphikLCG';
        src: url('/fonts/GraphikLCG-Regular.woff2') format('woff2');
        font-weight: 400;
        font-display: swap;
      }
      @font-face {
        font-family: 'GraphikLCG';
        src: url('/fonts/GraphikLCG-Medium.woff2') format('woff2');
        font-weight: 500;
        font-display: swap;
      }
      @font-face {
        font-family: 'GraphikLCG';
        src: url('/fonts/GraphikLCG-Semibold.woff2') format('woff2');
        font-weight: 600;
        font-display: swap;
      }
      @font-face {
        font-family: 'GraphikLCG';
        src: url('/fonts/GraphikLCG-Bold.woff2') format('woff2');
        font-weight: 700;
        font-display: swap;
      }

      /* ── Base ────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }

      html { -webkit-font-smoothing: antialiased; }

      /* ── Scrollbar ────────────────────────────────────── */
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
  </head>

  <body class="bg-[#0f0f0f] text-white font-sans antialiased overflow-x-hidden selection:bg-white/10">

    <!-- ── Minimal Navbar ─────────────────────────────── -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-[#0f0f0f]/90 backdrop-blur-sm border-b border-white/[0.06]">
      <nav class="max-w-[1400px] mx-auto px-8 md:px-12 h-[70px] flex items-center justify-between">

        <!-- Logo -->
        <a href="/" class="shrink-0">
          <img
            src="/images/ED-Digital-logo-black.svg"
            alt="ED Digital Agency"
            class="h-7 invert"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
          />
          <span style="display:none" class="font-bold text-sm tracking-tight text-white">ED Digital</span>
        </a>

        <!-- Nav links -->
        <ul class="hidden md:flex items-center gap-8 text-[13px] font-medium">
          <li>
            <a href="/servizi" class="text-white/40 hover:text-white transition-colors">
              Servizi
            </a>
          </li>
          <li>
            <a href="#casistudio" class="text-white/40 hover:text-white transition-colors">
              Progetti
            </a>
          </li>
          <li>
            <a href="mailto:ed.digitalagency@gmail.com" class="text-white/40 hover:text-white transition-colors">
              Contatti
            </a>
          </li>
          <li>
            <a
              href="mailto:ed.digitalagency@gmail.com"
              class="border border-white/20 text-white text-[13px] font-medium
                     px-5 py-2 rounded-full hover:bg-white hover:text-black
                     active:scale-95 transition-all duration-200"
            >
              Lavoriamo insieme
            </a>
          </li>
        </ul>

      </nav>
    </header>

    <main>
      <slot />
    </main>

    <!-- ── Footer ─────────────────────────────────────── -->
    <footer id="contatti" class="border-t border-white/[0.06] py-16 px-8 md:px-12">
      <div class="max-w-[1400px] mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
        <img
          src="/images/ED-Digital-logo-black.svg"
          alt="ED Digital Agency"
          class="h-6 invert"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block'"
        />
        <span style="display:none" class="font-bold text-sm text-white">ED Digital Agency</span>
        <p class="text-xs text-white/25">© 2026 ED Digital Agency. Tutti i diritti riservati.</p>
        <div class="flex gap-6 text-xs text-white/30">
          <a href="mailto:ed.digitalagency@gmail.com" class="hover:text-white transition-colors">
            ed.digitalagency@gmail.com
          </a>
          <span class="text-white/10">·</span>
          <a href="https://eddigitalagency.it" class="hover:text-white transition-colors">
            eddigitalagency.it
          </a>
        </div>
      </div>
    </footer>

  </body>
</html>
