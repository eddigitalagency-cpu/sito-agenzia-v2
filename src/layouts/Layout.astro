---
import Navbar from '../components/Navbar';
import CustomCursor from '../components/CustomCursor';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'ED Digital Agency — Il partner strategico per le piccole imprese italiane che vogliono crescere online. Social media, advertising, siti web, e-commerce, visual identity e automazioni.',
  ogImage = '/Images/Logo_Bianco_ED.webp',
} = Astro.props;

const canonicalURL  = new URL(Astro.url.pathname, 'https://eddigitalagency.it');
const fullTitle     = `${title} — ED Digital Agency`;
const ogImageAbs    = new URL(ogImage, 'https://eddigitalagency.it').toString();
---

<!doctype html>
<html lang="it" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- ── Primary SEO ──────────────────────────────────────── -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="agenzia digitale Treviso, agenzia marketing Treviso, web agency Vittorio Veneto, social media marketing Treviso, siti web Treviso, advertising Treviso, e-commerce Treviso, agenzia digitale Veneto, marketing digitale PMI, web design Treviso, SEO Treviso, agenzia comunicazione Treviso, ED Digital Agency" />
    <meta name="author" content="ED Digital Agency" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <link rel="canonical" href={canonicalURL} />

    <!-- ── Geo ─────────────────────────────────────────────── -->
    <meta name="geo.region" content="IT-TV" />
    <meta name="geo.placename" content="Vittorio Veneto, Treviso, Veneto" />
    <meta name="geo.position" content="45.9826;12.3001" />
    <meta name="ICBM" content="45.9826, 12.3001" />
    <meta name="DC.coverage" content="Vittorio Veneto, Treviso, Veneto, Italia" />

    <!-- ── Open Graph ──────────────────────────────────────── -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:site_name" content="ED Digital Agency" />

    <!-- ── Twitter Card ────────────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- ── Icons & Theme ───────────────────────────────────── -->
    <link rel="icon" type="image/png" href="/Images/Logo%20ED%20Digitla.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#FF6A00" />
    <meta name="msapplication-TileColor" content="#FF6A00" />

    <!-- ── JSON-LD Structured Data ─────────────────────────── -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": ["Organization", "LocalBusiness", "ProfessionalService"],
            "@id": "https://eddigitalagency.it/#organization",
            "name": "ED Digital Agency",
            "alternateName": ["ED Digital", "ED Digital Agency Treviso"],
            "url": "https://eddigitalagency.it",
            "logo": {
              "@type": "ImageObject",
              "url": "https://eddigitalagency.it/Images/Logo%20ED%20Digitla.png",
              "width": 400,
              "height": 400
            },
            "image": "https://eddigitalagency.it/Images/Logo%20ED%20Digitla.png",
            "description": "ED Digital Agency è l'agenzia digitale di riferimento a Vittorio Veneto e nella provincia di Treviso. Specializzata in social media marketing, advertising, siti web, e-commerce, visual identity e automazioni per PMI italiane.",
            "foundingDate": "2019",
            "telephone": "+39 379 3248371",
            "email": "info@eddigitalagency.it",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "Via Carlo Torres, 17/Interno 13",
              "addressLocality": "Vittorio Veneto",
              "addressRegion": "Treviso",
              "postalCode": "31029",
              "addressCountry": "IT"
            },
            "geo": {
              "@type": "GeoCoordinates",
              "latitude": 45.9826,
              "longitude": 12.3001
            },
            "areaServed": [
              { "@type": "City", "name": "Vittorio Veneto" },
              { "@type": "City", "name": "Treviso" },
              { "@type": "City", "name": "Conegliano" },
              { "@type": "City", "name": "Pieve di Soligo" },
              { "@type": "AdministrativeArea", "name": "Provincia di Treviso" },
              { "@type": "State", "name": "Veneto" },
              { "@type": "Country", "name": "Italia" }
            ],
            "contactPoint": {
              "@type": "ContactPoint",
              "telephone": "+39-379-3248371",
              "email": "info@eddigitalagency.it",
              "contactType": "customer service",
              "availableLanguage": "Italian",
              "areaServed": "IT"
            },
            "openingHoursSpecification": [{
              "@type": "OpeningHoursSpecification",
              "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
              "opens": "09:00",
              "closes": "18:00"
            }],
            "sameAs": [
              "https://www.instagram.com/eddigitalagency",
              "https://www.linkedin.com/company/ed-digital-agency"
            ],
            "knowsLanguage": "it",
            "priceRange": "€€",
            "hasOfferCatalog": {
              "@type": "OfferCatalog",
              "name": "Servizi Digitali per PMI",
              "itemListElement": [
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Social Media Management a Treviso", "url": "https://eddigitalagency.it/servizi/social-media-management" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Advertising Digitale a Treviso", "url": "https://eddigitalagency.it/servizi/advertising" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Siti Web a Treviso", "url": "https://eddigitalagency.it/servizi/website" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "E-Commerce a Treviso", "url": "https://eddigitalagency.it/servizi/ecommerce" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Foto e Video Professionale", "url": "https://eddigitalagency.it/servizi/photo-video" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Visual Identity e Logo Design", "url": "https://eddigitalagency.it/servizi/visual-identity" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sviluppo MVP e SaaS", "url": "https://eddigitalagency.it/servizi/mvp-saas" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sviluppo App Mobile", "url": "https://eddigitalagency.it/servizi/app" } },
                { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Integrazioni e Automazioni", "url": "https://eddigitalagency.it/servizi/integrazioni" } }
              ]
            },
            "aggregateRating": {
              "@type": "AggregateRating",
              "ratingValue": "5",
              "reviewCount": "200",
              "bestRating": "5"
            }
          },
          {
            "@type": "WebSite",
            "@id": "https://eddigitalagency.it/#website",
            "url": "https://eddigitalagency.it",
            "name": "ED Digital Agency — Agenzia Digitale Treviso",
            "description": "Agenzia digitale a Vittorio Veneto (Treviso). Social media, advertising, siti web, e-commerce, visual identity per PMI italiane.",
            "publisher": { "@id": "https://eddigitalagency.it/#organization" },
            "inLanguage": "it-IT",
            "potentialAction": {
              "@type": "SearchAction",
              "target": "https://eddigitalagency.it/servizi?q={search_term_string}",
              "query-input": "required name=search_term_string"
            }
          },
          {
            "@type": "WebPage",
            "@id": "https://eddigitalagency.it/#webpage",
            "url": "https://eddigitalagency.it",
            "name": "Agenzia Digitale a Treviso e Vittorio Veneto — ED Digital Agency",
            "isPartOf": { "@id": "https://eddigitalagency.it/#website" },
            "about": { "@id": "https://eddigitalagency.it/#organization" },
            "inLanguage": "it-IT",
            "speakable": {
              "@type": "SpeakableSpecification",
              "cssSelector": ["h1", "h2", ".speakable"]
            }
          },
          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Dove si trova ED Digital Agency?",
                "acceptedAnswer": { "@type": "Answer", "text": "ED Digital Agency ha sede a Vittorio Veneto, in provincia di Treviso (Veneto), in Via Carlo Torres 17. Operiamo in tutta la provincia di Treviso, il Veneto e su tutto il territorio italiano anche da remoto." }
              },
              {
                "@type": "Question",
                "name": "Quali servizi offre ED Digital Agency a Treviso?",
                "acceptedAnswer": { "@type": "Answer", "text": "Offriamo social media management, advertising su Meta e Google, sviluppo siti web e e-commerce, produzione foto e video, visual identity e logo design, sviluppo app e software, integrazioni e automazioni tra tool aziendali." }
              },
              {
                "@type": "Question",
                "name": "ED Digital Agency segue anche clienti fuori dalla provincia di Treviso?",
                "acceptedAnswer": { "@type": "Answer", "text": "Sì, lavoriamo con clienti in tutta Italia. Siamo specializzati in aziende a Vittorio Veneto, Conegliano, Treviso e nel Veneto, ma operiamo da remoto con PMI su tutto il territorio nazionale." }
              },
              {
                "@type": "Question",
                "name": "Quanto costa un sito web con ED Digital Agency a Treviso?",
                "acceptedAnswer": { "@type": "Answer", "text": "Il costo di un sito web varia in base alle esigenze del progetto. Offriamo soluzioni per PMI con prezzi competitivi. Contattaci per un preventivo gratuito e personalizzato entro 24 ore." }
              }
            ]
          }
        ]
      }
    </script>

    <!-- ── Flash prevention: apply saved theme before paint ── -->
    <script is:inline>
      (function(){var t=localStorage.getItem('ed-theme');if(t==='light')document.documentElement.classList.add('light');})();
    </script>

    <style is:global>
      /* ── Custom Fonts ──────────────────────────────────────── */
      @font-face {
        font-family: 'CalSans';
        src: url('/fonts/CalSans-Regular.ttf') format('truetype');
        font-weight: 400 700;
        font-display: swap;
      }
      @font-face { font-family:'GraphikLCG'; src:url('/fonts/GraphikLCG-Extralight.woff2') format('woff2'); font-weight:200; font-display:swap; }
      @font-face { font-family:'GraphikLCG'; src:url('/fonts/GraphikLCG-Light.woff2') format('woff2');      font-weight:300; font-display:swap; }
      @font-face { font-family:'GraphikLCG'; src:url('/fonts/GraphikLCG-Regular.woff2') format('woff2');    font-weight:400; font-display:swap; }
      @font-face { font-family:'GraphikLCG'; src:url('/fonts/GraphikLCG-Medium.woff2') format('woff2');     font-weight:500; font-display:swap; }
      @font-face { font-family:'GraphikLCG'; src:url('/fonts/GraphikLCG-Semibold.woff2') format('woff2');   font-weight:600; font-display:swap; }
      @font-face { font-family:'GraphikLCG'; src:url('/fonts/GraphikLCG-Bold.woff2') format('woff2');       font-weight:700; font-display:swap; }

      /* ── Theme Variables ─────────────────────────────────── */
      :root {
        --c-bg:      15,15,15;
        --c-surface: 20,20,20;
        --c-card:    26,26,26;
        --c-text:    255,255,255;
        --c-muted:   161,161,170;
        --partner-filter: invert(1);
      }
      html.light {
        --c-bg:      247,247,247;
        --c-surface: 255,255,255;
        --c-card:    237,237,237;
        --c-text:    15,15,15;
        --c-muted:   100,100,110;
        --partner-filter: none;
      }

      /* ── Theme Utilities ─────────────────────────────────── */
      .t-bg      { background-color: rgb(var(--c-bg))  !important; }
      .t-surface { background-color: rgb(var(--c-surface)) !important; }
      .t-card    { background-color: rgb(var(--c-card)) !important; }
      .t-text    { color: rgb(var(--c-text)) !important; }
      .t-muted   { color: rgb(var(--c-muted)) !important; }
      .t-border        { border-color: rgba(var(--c-text), 0.07) !important; }
      .t-border-subtle { border-color: rgba(var(--c-text), 0.05) !important; }
      .t-text-50  { color: rgba(var(--c-text), 0.50) !important; }
      .t-text-40  { color: rgba(var(--c-text), 0.40) !important; }
      .t-text-30  { color: rgba(var(--c-text), 0.30) !important; }
      .t-text-25  { color: rgba(var(--c-text), 0.25) !important; }

      /* ── Nav Themed Classes ──────────────────────────────── */
      .nav-bg    { background-color: rgba(var(--c-bg), 0.92); }
      .nav-border { border-bottom: 1px solid rgba(var(--c-text), 0.06); }
      .nav-link  { color: rgba(var(--c-text), 0.45); transition: color 0.2s ease; font-size: 13px; }
      .nav-link:hover { color: rgb(var(--c-text)); }
      .nav-cta   { border: 1px solid rgba(var(--c-text), 0.2); color: rgb(var(--c-text)); transition: all 0.2s ease; }
      .nav-cta:hover { background-color: #FF6A00; border-color: #FF6A00; color: #000; }
      .nav-icon-btn { color: rgba(var(--c-text), 0.5); transition: color 0.2s ease, background-color 0.2s ease; }
      .nav-icon-btn:hover { color: rgb(var(--c-text)); background-color: rgba(var(--c-text), 0.07); }
      .ham-bar { background-color: rgb(var(--c-text)); }

      /* ── Footer Themed Classes ───────────────────────────── */
      .footer-link { color: rgba(var(--c-text), 0.4); transition: color 0.2s ease; }
      .footer-link:hover { color: rgb(var(--c-text)); }
      .footer-heading { color: rgba(var(--c-text), 0.9); }
      .footer-dot  { color: rgba(var(--c-text), 0.15); }

      /* ── Smooth theme transition ─────────────────────────── */
      .t-bg,.t-surface,.t-card,.t-text,.t-muted,.t-border,.t-border-subtle,
      .t-text-50,.t-text-40,.t-text-30,.t-text-25,.nav-bg,.nav-border,
      .ham-bar, .footer-link {
        transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
      }

      /* ── Base ────────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }
      html { -webkit-font-smoothing: antialiased; }
      body { transition: background-color 0.3s ease, color 0.3s ease; }

      /* ── Remove 300ms tap delay on buttons/links ─────────── */
      a, button { touch-action: manipulation; }

      /* ── Hide cursor on desktop for custom cursor ─────────── */
      @media (pointer: fine) { * { cursor: none !important; } }

      /* ── Scrollbar ───────────────────────────────────────── */
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
  </head>

  <body class="t-bg t-text font-sans antialiased overflow-x-hidden">

    <Navbar client:load />

    <main>
      <slot />
    </main>

    <!-- ── Footer ──────────────────────────────────────────── -->
    <footer id="contatti" style="border-top:1px solid rgba(var(--c-text),0.06);">
      <div class="max-w-[1400px] mx-auto px-6 md:px-12 pt-16 pb-10">

        <!-- Top: logo + tagline + CTA -->
        <div class="flex flex-col md:flex-row md:items-start justify-between gap-10 mb-14">
          <div class="max-w-xs">
            <a href="/" aria-label="ED Digital Agency — Home">
              <img id="footer-logo" src="/Images/Logo%20ED%20Digitla.png" alt="ED Digital Agency" class="h-14 w-auto mb-5" loading="lazy" />
            </a>
            <p class="text-sm leading-relaxed" style="color:rgba(var(--c-muted),1)">
              Il partner strategico per le PMI italiane che vogliono crescere nel digitale.
            </p>
          </div>

          <a href="/contatti"
            class="self-start inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold uppercase tracking-widest transition-all duration-200 active:scale-95"
            style="background:#FF6A00; color:#000;">
            Inizia un progetto →
          </a>
        </div>

        <!-- Nav columns -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-14">

          <!-- Servizi -->
          <div>
            <p class="footer-heading text-xs font-semibold uppercase tracking-[0.18em] mb-5">Servizi</p>
            <ul class="space-y-3 text-sm">
              <li><a href="/servizi/social-media-management" class="footer-link">Social Media</a></li>
              <li><a href="/servizi/advertising" class="footer-link">Advertising</a></li>
              <li><a href="/servizi/website" class="footer-link">Website</a></li>
              <li><a href="/servizi/ecommerce" class="footer-link">E-Commerce</a></li>
              <li><a href="/servizi/photo-video" class="footer-link">Photo & Video</a></li>
              <li><a href="/servizi/visual-identity" class="footer-link">Visual Identity</a></li>
              <li><a href="/servizi/mvp-saas" class="footer-link">MVP & SaaS</a></li>
              <li><a href="/servizi/app" class="footer-link">App</a></li>
              <li><a href="/servizi/integrazioni" class="footer-link">Integrazioni</a></li>
            </ul>
          </div>

          <!-- Agenzia -->
          <div>
            <p class="footer-heading text-xs font-semibold uppercase tracking-[0.18em] mb-5">Agenzia</p>
            <ul class="space-y-3 text-sm">
              <li><a href="/" class="footer-link">Home</a></li>
              <li><a href="/servizi" class="footer-link">Servizi</a></li>
              <li><a href="/#casistudio" class="footer-link">Progetti</a></li>
              <li><a href="/contatti" class="footer-link">Contatti</a></li>
            </ul>
          </div>

          <!-- Contatti -->
          <div class="col-span-2 md:col-span-2">
            <p class="footer-heading text-xs font-semibold uppercase tracking-[0.18em] mb-5">Contatti</p>
            <ul class="space-y-3 text-sm">
              <li>
                <a href="mailto:info@eddigitalagency.it" class="footer-link flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  info@eddigitalagency.it
                </a>
              </li>
              <li>
                <a href="tel:+393793248371" class="footer-link flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.1 6.1l.91-.9a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  +39 379 324 8371
                </a>
              </li>
              <li>
                <a href="https://maps.google.com/?q=Via+Carlo+Torres+17+Vittorio+Veneto+TV" target="_blank" rel="noopener noreferrer" class="footer-link flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  Via Carlo Torres 17, Vittorio Veneto (TV)
                </a>
              </li>
            </ul>
          </div>
        </div>

        <!-- Bottom bar -->
        <div style="border-top:1px solid rgba(var(--c-text),0.06); padding-top:2rem;"
          class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="text-xs" style="color:rgba(var(--c-text),0.25);">
            © 2026 ED Digital Agency. Tutti i diritti riservati.
          </p>
          <p class="text-xs" style="color:rgba(var(--c-text),0.20);">
            Vittorio Veneto (TV) · Italia
          </p>
          <!-- Social icons -->
          <div class="flex items-center gap-4">
            <a href="https://instagram.com/eddigitalagency" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
            </a>
            <a href="https://linkedin.com/company/ed-digital-agency" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="LinkedIn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Footer logo inversion follows theme -->
    <script is:inline>
      (function(){
        function syncLogo(){
          var el=document.getElementById('footer-logo');
          if(el) el.style.filter=document.documentElement.classList.contains('light')?'invert(1)':'none';
        }
        syncLogo();
        var obs=new MutationObserver(syncLogo);
        obs.observe(document.documentElement,{attributes:true,attributeFilter:['class']});
      })();
    </script>

    <!-- Page view tracking -->
    <script is:inline>
      (function(){
        try {
          fetch('/api/track', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ path: window.location.pathname, referrer: document.referrer || null }),
            keepalive: true,
          });
        } catch(e) {}
      })();
    </script>

    <CustomCursor client:load />

  </body>
</html>
